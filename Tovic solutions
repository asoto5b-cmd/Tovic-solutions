    <!-- LOGICA JS -->
    <script>
        const config = {
            categories: {
                enrollable: {
                    name: "Mosquitera Enrollable",
                    desc: "Sistema que se recoge automáticamente en un cajetín.",
                    sub: {
                        rele: { label: "Rele", desc: "Ancho máx: 1600 mm | Altura máx: 2500 mm", minW: 0, maxW: 1600, minH: 0, maxH: 2500, price: 45 },
                        "qatif-life": { label: "Qatif Life", desc: "Ancho: 1500 a 5000 mm | Altura máx: 3500 mm", minW: 1500, maxW: 5000, minH: 0, maxH: 3500, price: 110 },
                        swing: { label: "Swing", desc: "Ancho: 640 a 1600 mm | Altura máx: 2400 mm", minW: 640, maxW: 1600, minH: 0, maxH: 2400, price: 65 },
                        "swing-doble": { label: "Swing Doble", desc: "Ancho: 1280 a 3200 mm | Altura máx: 2400 mm", minW: 1280, maxW: 3200, minH: 0, maxH: 2400, price: 120 },
                        "modelo-l": { label: "Modelo L", desc: "Ancho: 640 a 1600 mm | Altura máx: 2400 mm", minW: 640, maxW: 1600, minH: 0, maxH: 2400, price: 55 },
                        "modelo-l-doble": { label: "Modelo L Doble", desc: "Ancho: 1280 a 3200 mm | Altura máx: 2400 mm", minW: 1280, maxW: 3200, minH: 0, maxH: 2400, price: 105 },
                        lateral: { label: "Lateral", desc: "Ancho: 610 a 1200 mm | Altura máx: 2300 mm", minW: 610, maxW: 1200, minH: 0, maxH: 2300, price: 75 },
                        "lateral-doble": { label: "Lateral Doble", desc: "Ancho máx: 2400 mm | Altura máx: 2300 mm", minW: 0, maxW: 2400, minH: 0, maxH: 2300, price: 145 },
                        "noche-dia": { label: "Noche y Día", desc: "Ancho: 640 a 1100 mm | Altura máx: 1400 mm", minW: 640, maxW: 1100, minH: 0, maxH: 1400, price: 90 }
                    }
                },
                plisada: { name: "Mosquitera Plisada", desc: "Tejido en acordeón de máxima elegancia.", price: 90 },
                corredera: { name: "Mosquitera Corredera", desc: "Especial para perfiles de ventana corredera.", price: 40 },
                alicantina: { name: "Persiana Alicantina", desc: "Tradición leonesa de alta durabilidad.", price: 50 }
            }
        };

        let currentCat = null;
        let currentColor = 'blanco';

        function showPage(page) {
            document.querySelectorAll('.page').forEach(p => p.classList.add('hidden'));
            document.getElementById(`page-${page}`).classList.remove('hidden');
            window.scrollTo(0, 0);
        }

        function selectCategory(cat) {
            currentCat = cat;
            document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('border-tovic-red', 'bg-red-50'));
            event.currentTarget.classList.add('border-tovic-red', 'bg-red-50');
            
            const sub = document.getElementById('subcat-container');
            if (cat === 'enrollable') {
                sub.classList.remove('hidden');
            } else {
                sub.classList.add('hidden');
                document.getElementById('subcat-select').value = "";
                document.getElementById('model-description').innerText = "";
            }
            calculatePrice();
        }

        function setColor(c) {
            currentColor = c;
            document.querySelectorAll('.color-dot').forEach(d => d.classList.remove('ring-4', 'ring-tovic-red'));
            event.currentTarget.classList.add('ring-4', 'ring-tovic-red');
            document.getElementById('color-label').innerText = c + " seleccionado";
            calculatePrice();
        }

        function updateModelLimits() {
            const val = document.getElementById('subcat-select').value;
            const desc = document.getElementById('model-description');
            if (val) {
                desc.innerText = config.categories.enrollable.sub[val].desc;
            } else {
                desc.innerText = "";
            }
            calculatePrice();
        }

        function calculatePrice() {
            if (!currentCat) return;

            const ancho = parseInt(document.getElementById('input-ancho').value) || 0;
            const alto = parseInt(document.getElementById('input-alto').value) || 0;
            const qty = parseInt(document.getElementById('input-cantidad').value) || 1;
            const malla = document.getElementById('malla-select').value;
            const instala = document.getElementById('check-instala').checked;
            const subSelect = document.getElementById('subcat-select').value;

            let priceBase = 0;
            let summary = "";
            let valid = true;

            document.getElementById('limit-ancho').innerText = "";
            document.getElementById('limit-alto').innerText = "";

            if (currentCat === 'enrollable') {
                if (!subSelect) {
                    summary = "<p>Seleccione modelo de mosquitera enrollable.</p>";
                    valid = false;
                } else {
                    const model = config.categories.enrollable.sub[subSelect];
                    priceBase = model.price;
                    if (ancho > 0 && (ancho < model.minW || ancho > model.maxW)) {
                        document.getElementById('limit-ancho').innerText = `Límite: ${model.minW}-${model.maxW}mm`;
                        valid = false;
                    }
                    if (alto > 0 && (alto < model.minH || alto > model.maxH)) {
                        document.getElementById('limit-alto').innerText = `Límite: ${model.minH}-${model.maxH}mm`;
                        valid = false;
                    }
                    summary = `<p><strong>Modelo:</strong> ${model.label}</p>`;
                }
            } else {
                priceBase = config.categories[currentCat].price;
                summary = `<p><strong>Tipo:</strong> ${config.categories[currentCat].name}</p>`;
            }

            if (valid && ancho > 0 && alto > 0) {
                let m2 = (ancho * alto) / 1000000;
                let unitPrice = priceBase + (m2 * 30);
                
                if (malla === 'antipolen') unitPrice += 15;
                if (malla === 'mascotas') unitPrice += 25;
                if (currentColor === 'madera') unitPrice += 15;
                if (instala) unitPrice += 45;

                let total = unitPrice * qty;
                if (qty >= 5) {
                    total = total * 0.9;
                    document.getElementById('volume-discount').classList.remove('hidden');
                } else {
                    document.getElementById('volume-discount').classList.add('hidden');
                }

                summary += `
                    <p><strong>Dimensiones:</strong> ${ancho} x ${alto} mm</p>
                    <p><strong>Color:</strong> ${currentColor.toUpperCase()}</p>
                    <p><strong>Tejido:</strong> ${malla}</p>
                    <p><strong>Instalación:</strong> ${instala ? 'SÍ' : 'NO'}</p>
                `;
                
                document.getElementById('final-price').innerText = total.toFixed(2) + "€";
                document.getElementById('summary-details').innerHTML = summary;
            } else {
                document.getElementById('final-price').innerText = "0.00€";
                if (valid) document.getElementById('summary-details').innerHTML = "<p class='text-center text-gray-400'>Introduzca medidas para calcular...</p>";
                else document.getElementById('summary-details').innerHTML = summary;
            }
        }

        function processPayment() {
            if (document.getElementById('final-price').innerText === "0.00€") {
                alert("Primero configure su mosquitera con medidas válidas.");
                return;
            }
            alert("Redirigiendo a pasarela segura de Tovic Solutions...");
        }

        window.onload = () => console.log("Tovic Solutions Online");
    </script>
</body>
</html>
